{
  "name": "errorline-system-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "generate": "openapi-generator-cli generate -i errorline-system-swagger.json -g typescript-axios -o generated-sources/openapi --additional-properties=ngVersion=6.1.7,npmName=restClient,supportsES6=true,npmVersion=6.9.0,withInterfaces=true",
    "dev": "npm run generate && vite",
    "build": "npm run generate && tsc && vite build",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mantine/core": "7.12.2",
    "@mantine/form": "^7.17.2",
    "@mantine/hooks": "7.12.2",
    "@openapitools/openapi-generator-cli": "^2.19.1",
    "@tabler/icons-react": "^3.31.0",
    "axios": "^1.8.3",
    "jwt-decode": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "postcss": "^8.4.38",
    "postcss-preset-mantine": "1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  },
  "packageManager": "yarn@4.4.1"
}
